---
import { getRoadmapTasks } from '../lib/notion';
import { processRoadmapTasks } from '../lib/roadmap';
import '../styles/global.css';

const tasks = await getRoadmapTasks();
const sections = processRoadmapTasks(tasks);

const now = new Date();
const buildTime = now.toLocaleString('ja-JP', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
});
const year = now.getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MeMory アプリの開発ロードマップ" />
    <title>MeMory Roadmap</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <h1 class="site-title">MeMory Roadmap</h1>
      </div>
    </header>

    <main>
      <div class="container">
        {sections.map((section) => {
          const extraId = `extra-${section.notion.replace(/\s+/g, '-')}`;
          return (
            <section class="section">
              <h2 class="section-title" style={`color: ${section.color}`}>
                {section.label}
              </h2>

              {section.initialTasks.length === 0 && !section.hasMore ? (
                <p class="empty-note">現在このステータスのタスクはありません</p>
              ) : (
                <ul class="task-list">
                  {section.initialTasks.map((task) => (
                    <li class="task-card">{task.title}</li>
                  ))}
                </ul>
              )}

              {section.hasMore && (
                <Fragment>
                  <ul class="task-list extra-tasks" id={extraId}>
                    {section.extraTasks.map((task) => (
                      <li class="task-card">{task.title}</li>
                    ))}
                  </ul>
                  <button class="more-btn" data-target={extraId}>
                    もっと見る（あと{section.extraTasks.length}件）
                  </button>
                </Fragment>
              )}
            </section>
          );
        })}
      </div>
    </main>

    <footer class="site-footer">
      <p>© {year} LovaMe</p>
      <p>最終更新: {buildTime}</p>
    </footer>

    <script>
      document.querySelectorAll('.more-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (!targetId) return;
          const target = document.getElementById(targetId);
          if (target) {
            target.classList.remove('extra-tasks');
            btn.remove();
          }
        });
      });
    </script>
  </body>
</html>
